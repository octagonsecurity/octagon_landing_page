{
  "buildCommand": "node scripts/prepare-deploy.mjs",
  "outputDirectory": "dist",
  "redirects": [
    { "source": "/about-us", "destination": "/about/", "permanent": true },
    { "source": "/contact", "destination": "/#contact", "permanent": true },
    { "source": "/reviews", "destination": "/#reviews", "permanent": true },
    { "source": "/faqs", "destination": "/#services", "permanent": true },
    { "source": "/faq", "destination": "/#services", "permanent": true },
    { "source": "/faq-home", "destination": "/#services", "permanent": true },
    { "source": "/gallery", "destination": "/", "permanent": true },
    { "source": "/areas-we-serve", "destination": "/", "permanent": true },
    { "source": "/areas-we-serve/:path*", "destination": "/", "permanent": true },
    { "source": "/miami-dade", "destination": "/", "permanent": true },
    { "source": "/broward", "destination": "/", "permanent": true },
    { "source": "/service-area/:path*", "destination": "/", "permanent": true },
    { "source": "/about.html", "destination": "/about/", "permanent": true },
    {
      "source": "/service.html",
      "has": [{ "type": "query", "key": "s", "value": "(?<slug>.*)" }],
      "destination": "/services/:slug/",
      "permanent": true
    },
    { "source": "/service.html", "destination": "/services/home-security/", "permanent": true },
    { "source": "/security-camera-faq", "destination": "/services/cameras/", "permanent": true },
    { "source": "/fire-alarm-faq", "destination": "/services/fire-alarm/", "permanent": true },
    { "source": "/burglar-alarm-faq", "destination": "/services/burglar-alarm/", "permanent": true },
    { "source": "/home-and-business-security-system-installation", "destination": "/services/home-security/", "permanent": true },
    { "source": "/security-system-installation-miami", "destination": "/services/home-security/", "permanent": true },
    { "source": "/services/home-security", "destination": "/services/home-security/", "permanent": true },
    { "source": "/smart-security-cameras-and-video-surveillance-systems", "destination": "/services/cameras/", "permanent": true },
    { "source": "/services/cameras", "destination": "/services/cameras/", "permanent": true },
    { "source": "/burglar-alarm-installation-and-intrusion-detection", "destination": "/services/burglar-alarm/", "permanent": true },
    { "source": "/services/burglar-alarm", "destination": "/services/burglar-alarm/", "permanent": true },
    { "source": "/fire-alarm-systems-and-smoke-detection-installation", "destination": "/services/fire-alarm/", "permanent": true },
    { "source": "/services/fire-alarm", "destination": "/services/fire-alarm/", "permanent": true },
    { "source": "/access-control-systems-and-keyless-entry-solutions", "destination": "/services/access-control/", "permanent": true },
    { "source": "/access-control-faq", "destination": "/services/access-control/", "permanent": true },
    { "source": "/services/access-control", "destination": "/services/access-control/", "permanent": true },
    { "source": "/structured-cabling", "destination": "/services/structured-cabling/", "permanent": true },
    { "source": "/structured-cabling-and-network-infrastructure", "destination": "/services/structured-cabling/", "permanent": true },
    { "source": "/structured-cabling-faq", "destination": "/services/structured-cabling/", "permanent": true },
    { "source": "/services/structured-cabling", "destination": "/services/structured-cabling/", "permanent": true },
    { "source": "/warehouse-security-systems-in-miami-dade", "destination": "/services/warehouse/", "permanent": true },
    { "source": "/services/warehouse", "destination": "/services/warehouse/", "permanent": true }
  ]
}