# Set in Vercel → Project Settings → Environment Variables
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Optional — from your Google Maps URL (!1s0xa381d5e2d395b453:0x2abe88d9761ffa3e)
# GOOGLE_PLACE_CID=3080049662739085886

# Optional — only if CID lookup fails. Fresh ChIJ id from Place ID Finder:
# GOOGLE_PLACE_ID=ChIJxxxxxxxxxxxxxxxxxxxx
